#!/bin/sh
set -e

while read -r _local_ref _local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      echo "[hooks] Direct pushes to '$remote_ref' are blocked." >&2
      echo "[hooks] Push a feature branch and create a PR instead." >&2
      exit 1
      ;;
  esac
done

exit 0
